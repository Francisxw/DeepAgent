# ============================================
# DeepResearchBot 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# ============================================

# ============================================
# LLM 配置
# ============================================
LLM=qwen-max
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEXT_EMBEDDING=text-embedding-v4

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=pharma_db

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# MongoDB 配置
# ============================================
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=chat_memory_db
MONGODB_CHAT_COLLECTION=deepsearch_agent
MONGODB_MEMORY_TTL_DAYS=30

# ============================================
# JWT 认证配置
# ============================================
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ============================================
# 百度搜索配置 (可选)
# ============================================
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key

# ============================================
# RAGFlow 配置 (可选)
# ============================================
RAGFLOW_API_KEY=your-ragflow-api-key
RAGFLOW_API_URL=http://localhost:9380
